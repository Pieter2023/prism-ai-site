---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://prismaiservices.ca';
const pageUrl = `${siteUrl}/about`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Pieter van der Walt',
      jobTitle: 'Founder',
      worksFor: {
        '@type': 'LocalBusiness',
        name: 'Prism AI',
        url: siteUrl,
      },
      url: pageUrl,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Kelowna',
        addressRegion: 'BC',
        addressCountry: 'CA',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: 'About', item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title="About Pieter van der Walt | Prism AI | Kelowna, BC"
  description="Meet Pieter van der Walt, founder of Prism AI. Based in Kelowna, BC, helping Okanagan businesses automate operations with AI voice agents and workflow automation."
  canonical={pageUrl}
  jsonLd={jsonLd}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a> <span>/</span>
      <span class="current">About</span>
    </div>
  </nav>

  <section class="about-hero">
    <div class="container">
      <h1>About <span class="text-gradient">Prism AI</span></h1>
      <p class="hero-subtitle">Real AI automation, built by a real person, in a real place.</p>
      <div class="quick-answer">
        <h2>Quick answer:</h2>
        <p>Prism AI helps Canadian service businesses implement fixed-fee AI voice agent and workflow automation systems, with practical delivery, clear pricing, and direct founder-led support from Kelowna, BC.</p>
      </div>
    </div>
  </section>

  <section class="about-content">
    <div class="container about-container">
      <div class="about-main">
        <h2>Hey, I'm Pieter.</h2>
        <p>
          I'm the founder of Prism AI, based right here in Kelowna, BC. I started this company
          because I kept seeing the same thing: small business owners drowning in manual work that a well-built
          AI system could handle in seconds. Missed calls after hours. Hours spent copying data between
          spreadsheets. Follow-ups that fell through the cracks. It did not have to be that way.
        </p>
        <p>
          Before starting Prism AI, I spent years in real estate and technology, which gave me a front-row
          seat to how much time gets wasted on repetitive tasks. When AI voice technology and automation
          platforms matured enough to actually deliver on their promises, I knew it was time to build something
          that helps real businesses — not just enterprise companies with six-figure budgets.
        </p>

        <h2>Why Kelowna?</h2>
        <p>
          I chose Kelowna because it is one of the best places to live and work in Canada — and I mean that
          genuinely. When I am not building AI systems, you will find me mountain biking the trails above
          the lake, exploring the wine country, or just enjoying the Okanagan lifestyle that drew so many of
          us here. This is not just where I work. It is home.
        </p>
        <p>
          Being local matters. I understand the Okanagan economy — the seasonal spikes that hit wineries and
          tourism operators, the construction boom keeping trades companies busier than ever, the real estate
          market that moves at all hours. When I build automation for your business, it is designed for how
          things actually work here, not based on assumptions from a desk in Toronto.
        </p>

        <h2>What Prism AI Stands For</h2>
        <div class="values-grid">
          <div class="value-item">
            <h3>Practical Over Flashy</h3>
            <p>We build solutions that actually save you time and money — not demos that look cool but collect dust. Every project starts with "what's costing you the most time right now?"</p>
          </div>
          <div class="value-item">
            <h3>Honest Pricing</h3>
            <p>Fixed-fee project packages in Canadian dollars, with optional monthly retainers. No hidden fees, no surprise invoices, and no vague scope creep. You know exactly what you are paying for.</p>
          </div>
          <div class="value-item">
            <h3>Canadian-First</h3>
            <p>Built with PIPEDA and BC's PIPA compliance from day one. Your data stays secure and your business stays compliant with Canadian privacy law.</p>
          </div>
          <div class="value-item">
            <h3>Real Support</h3>
            <p>When you email pieter@prismaiservices.ca, you get a response from me — not a chatbot, not a ticket number. I stand behind every system we build.</p>
          </div>
        </div>

        <div class="cta-block">
          <h3>Want to See What AI Can Do for Your Business?</h3>
          <p>Talk to our AI concierge for a free 2-minute assessment, or just reach out directly.</p>
          <div class="cta-actions">
            <a href="/#talk-to-ai" class="btn-primary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Talk to Our AI</a>
            <a href="mailto:pieter@prismaiservices.ca" class="btn-secondary">Email Me Directly</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb { padding: 1rem 0; font-size: 0.875rem; color: var(--color-text-muted); }
  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-primary-light); }
  .breadcrumb span { margin: 0 0.5rem; }
  .breadcrumb .current { color: var(--color-text); }

  .about-hero {
    padding: 4rem 0 2rem; text-align: center;
    background: radial-gradient(ellipse at top, rgba(108, 60, 225, 0.1) 0%, transparent 55%);
  }
  .about-hero h1 { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .hero-subtitle { font-size: 1.2rem; color: var(--color-text-muted); }
  .quick-answer {
    max-width: 860px;
    margin: 1.25rem auto 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    background: rgba(6, 182, 212, 0.08);
    text-align: left;
  }
  .quick-answer h2 { font-size: 1rem; margin-bottom: 0.35rem; color: var(--color-secondary); }
  .quick-answer p { margin: 0; line-height: 1.7; }

  .about-content { padding: 3rem 0 5rem; }
  .about-container { max-width: 760px; }

  .about-main h2 { font-size: 1.5rem; margin: 2.5rem 0 1rem; color: var(--color-text-heading); }
  .about-main h2:first-child { margin-top: 0; }
  .about-main p { line-height: 1.8; margin-bottom: 1.25rem; color: var(--color-text-muted); font-size: 1.05rem; }

  .values-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem; margin: 2rem 0;
  }
  .value-item {
    padding: 1.5rem; border: 1px solid var(--color-border);
    border-radius: var(--radius); background: rgba(108, 60, 225, 0.04);
  }
  .value-item h3 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--color-primary-light); }
  .value-item p { color: var(--color-text-muted); line-height: 1.7; font-size: 0.95rem; margin: 0; }

  .cta-block {
    margin-top: 3rem; padding: 2.5rem; text-align: center;
    background: linear-gradient(135deg, rgba(108, 60, 225, 0.12), rgba(6, 182, 212, 0.08));
    border: 1px solid rgba(108, 60, 225, 0.25); border-radius: var(--radius);
  }
  .cta-block h3 { font-size: 1.3rem; margin-bottom: 0.75rem; }
  .cta-block p { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
