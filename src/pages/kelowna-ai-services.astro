---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';

const siteUrl = 'https://prismaiservices.ca';
const pageUrl = `${siteUrl}/kelowna-ai-services`;

const faqItems = [
  {
    question: 'Do you work with businesses outside of Kelowna?',
    answer: 'Yes. While we are based in Kelowna and most of our clients are in the Okanagan, we serve businesses across British Columbia and all of Canada. AI voicebots and workflow automation work the same whether you are down the street or across the country.',
  },
  {
    question: 'What industries in the Okanagan do you specialize in?',
    answer: 'We work extensively with wineries and tourism operators dealing with seasonal booking surges, trades companies managing job requests in the field, real estate agencies capturing after-hours leads, and healthcare clinics streamlining patient booking. These are the industries that benefit most from AI automation in this region.',
  },
  {
    question: 'Can we meet in person?',
    answer: 'Absolutely. We are based right here in Kelowna and happy to meet for coffee to discuss your project. We also cover West Kelowna, Penticton, Vernon, and anywhere in the Central Okanagan.',
  },
  {
    question: 'How much does it cost?',
    answer: 'Our plans start at $497 CAD per month for a single voicebot or automation workflow. We offer transparent pricing with no hidden fees and no long-term contracts. Visit our pricing page or talk to our AI concierge for a personalized recommendation.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': `${siteUrl}/#business`,
      name: 'Prism AI Services',
      description: 'AI voicebots and workflow automation for Kelowna, West Kelowna, Penticton, Vernon, and the Okanagan Valley.',
      url: siteUrl,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Kelowna',
        addressRegion: 'BC',
        addressCountry: 'CA',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 49.8880,
        longitude: -119.4960,
      },
      areaServed: [
        { '@type': 'City', name: 'Kelowna' },
        { '@type': 'City', name: 'West Kelowna' },
        { '@type': 'City', name: 'Penticton' },
        { '@type': 'City', name: 'Vernon' },
        { '@type': 'AdministrativeArea', name: 'Central Okanagan' },
      ],
      priceRange: '$$',
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '09:00',
        closes: '17:00',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map(f => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: 'Kelowna AI Services', item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title="AI Services in Kelowna & the Okanagan | Voicebots & Automation | Prism AI"
  description="Kelowna-based AI automation for wineries, tourism, trades, real estate, and healthcare. AI voicebots and workflow automation serving Kelowna, West Kelowna, Penticton, and Vernon."
  canonical={pageUrl}
  jsonLd={jsonLd}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a> <span>/</span>
      <span class="current">Kelowna AI Services</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="geo-hero">
    <div class="container">
      <div class="hero-badge">Proudly Based in Kelowna, BC</div>
      <h1>AI Automation for<br /><span class="text-gradient">Kelowna &amp; the Okanagan</span></h1>
      <p class="hero-sub">
        From downtown Kelowna to West Kelowna, Penticton, and Vernon — we help
        Okanagan businesses automate their operations with AI voicebots and workflow automation.
        Local expertise, built for how you do business here.
      </p>
      <div class="hero-actions">
        <a href="/#talk-to-ai" class="btn-primary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Talk to Our AI — Free</a>
        <a href="/services" class="btn-secondary">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Local Economy -->
  <section class="local-economy">
    <div class="container">
      <h2>Built for the Okanagan Economy</h2>
      <p class="section-intro">
        The Okanagan is not just another market to us — it is home. We understand the seasonal rhythms,
        the industries that drive this region, and the unique challenges local businesses face.
      </p>
      <div class="industry-grid">
        <div class="industry-card card">
          <h3>Wineries &amp; Agriculture</h3>
          <p>
            The Okanagan is home to over 300 wineries and a booming agri-tourism industry. Seasonal booking
            surges during wine tour season can overwhelm small teams. Our AI voicebots handle reservation
            inquiries, tasting room bookings, and event information — so you can focus on making great wine.
          </p>
        </div>
        <div class="industry-card card">
          <h3>Tourism &amp; Hospitality</h3>
          <p>
            From ski resorts in winter to lakeside hotels in summer, Okanagan tourism operators deal with
            massive seasonal demand swings. Workflow automation keeps your booking systems, guest communications,
            and team coordination running smoothly without scaling up your front desk staff.
          </p>
        </div>
        <div class="industry-card card">
          <h3>Trades &amp; Contractors</h3>
          <p>
            Kelowna's construction and renovation boom means trades businesses are busier than ever. But if
            you are on a job site, you cannot answer the phone. AI voicebots capture job requests, provide
            quotes, and schedule estimates — so you never lose work because you were too busy working.
          </p>
        </div>
        <div class="industry-card card">
          <h3>Real Estate</h3>
          <p>
            The Okanagan real estate market moves fast. When a buyer calls about a listing at 9 PM, they
            expect an answer — not voicemail. Our AI qualifies buyer and seller leads, schedules showings,
            and answers property questions any time of day.
          </p>
        </div>
        <div class="industry-card card">
          <h3>Healthcare &amp; Dental</h3>
          <p>
            Clinics across the Central Okanagan are dealing with growing patient volumes and limited admin
            staff. AI-powered appointment booking, prescription refill requests, and patient intake automation
            reduce the burden on your front desk — all fully compliant with PIPEDA and PIPA.
          </p>
        </div>
        <div class="industry-card card">
          <h3>Professional Services</h3>
          <p>
            Law firms, accounting practices, and consulting firms in Kelowna lose hours to manual client
            onboarding, document management, and scheduling. We automate the administrative layer so your
            team can bill more hours on actual client work.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="area-section">
    <div class="container">
      <h2>Serving the Entire Okanagan Valley</h2>
      <div class="area-grid">
        <div class="area-card">
          <h3>Kelowna</h3>
          <p>Our home base. We know the business community here inside and out.</p>
        </div>
        <div class="area-card">
          <h3>West Kelowna</h3>
          <p>Just across the bridge. Many of our winery and trades clients are based here.</p>
        </div>
        <div class="area-card">
          <h3>Penticton</h3>
          <p>Tourism hub with a growing tech sector. Perfect fit for AI automation.</p>
        </div>
        <div class="area-card">
          <h3>Vernon</h3>
          <p>North Okanagan businesses benefit from the same AI tools as downtown Kelowna.</p>
        </div>
      </div>
      <p class="area-note">
        Our services are not limited to in-person meetings. We work with businesses across BC and Canada remotely.
        But if you are in the Okanagan, we are always happy to meet face to face.
      </p>
    </div>
  </section>

  <!-- Why Local Matters -->
  <section class="why-local">
    <div class="container">
      <div class="why-card">
        <h2>Why a Local AI Partner Matters</h2>
        <p>
          You could hire an agency in Toronto or a freelancer overseas. But they will never understand
          why your winery gets 300 calls in a single weekend during Harvest Festival, or why your HVAC company
          needs to capture emergency calls at 2 AM in January. We live here. We get it.
        </p>
        <p>
          Working with Prism AI means working with someone who understands the Okanagan economy, knows the
          seasonal patterns, and can meet you for coffee at Sprout to talk through your automation needs.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={faqItems} heading="Kelowna AI Services FAQ" />

  <!-- CTA -->
  <section class="geo-cta">
    <div class="container">
      <div class="cta-card">
        <h2>Let's Talk About Your Business</h2>
        <p>Based in the Okanagan? Talk to our AI concierge right now — or reach out to schedule a coffee meeting in Kelowna.</p>
        <div class="cta-actions">
          <a href="/#talk-to-ai" class="btn-primary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Talk to Our AI</a>
          <a href="mailto:pieter@prismaiservices.ca" class="btn-secondary">Email Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb { padding: 1rem 0; font-size: 0.875rem; color: var(--color-text-muted); }
  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-primary-light); }
  .breadcrumb span { margin: 0 0.5rem; }
  .breadcrumb .current { color: var(--color-text); }

  .geo-hero {
    padding: 5rem 0 4rem; text-align: center;
    background: radial-gradient(ellipse at top, rgba(108, 60, 225, 0.12) 0%, transparent 60%);
  }
  .hero-badge {
    display: inline-block; padding: 0.5rem 1.25rem;
    background: rgba(6, 182, 212, 0.12); border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: 999px; font-size: 0.9rem; font-weight: 600;
    color: var(--color-secondary); margin-bottom: 1.5rem;
  }
  .geo-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: 1.5rem; }
  .hero-sub { font-size: 1.15rem; color: var(--color-text-muted); max-width: 650px; margin: 0 auto 2.5rem; line-height: 1.7; }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .local-economy h2 { font-size: 1.75rem; text-align: center; margin-bottom: 1rem; }
  .section-intro { text-align: center; color: var(--color-text-muted); max-width: 650px; margin: 0 auto 2.5rem; line-height: 1.8; font-size: 1.05rem; }
  .industry-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; }
  .industry-card h3 { font-size: 1.15rem; margin-bottom: 0.75rem; color: var(--color-primary-light); }
  .industry-card p { color: var(--color-text-muted); line-height: 1.7; font-size: 0.95rem; }

  .area-section { background: var(--color-bg-card); }
  .area-section h2 { font-size: 1.75rem; text-align: center; margin-bottom: 2.5rem; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
  .area-card {
    text-align: center; padding: 2rem; border: 1px solid var(--color-border);
    border-radius: var(--radius); background: rgba(108, 60, 225, 0.04);
  }
  .area-card h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
  .area-card p { color: var(--color-text-muted); font-size: 0.9rem; }
  .area-note { text-align: center; color: var(--color-text-muted); font-size: 0.95rem; max-width: 600px; margin: 0 auto; }

  .why-local { padding: 5rem 0; }
  .why-card { max-width: 700px; margin: 0 auto; }
  .why-card h2 { font-size: 1.75rem; margin-bottom: 1.5rem; text-align: center; }
  .why-card p { color: var(--color-text-muted); line-height: 1.8; font-size: 1.05rem; margin-bottom: 1rem; }

  .geo-cta { padding: 0 0 5rem; }
  .cta-card {
    text-align: center; max-width: 600px; margin: 0 auto;
    background: linear-gradient(135deg, rgba(108, 60, 225, 0.12), rgba(6, 182, 212, 0.08));
    border: 1px solid rgba(108, 60, 225, 0.25); border-radius: var(--radius); padding: 3rem 2rem;
  }
  .cta-card h2 { font-size: 1.5rem; margin-bottom: 1rem; }
  .cta-card p { color: var(--color-text-muted); margin-bottom: 2rem; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
