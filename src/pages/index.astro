---
/**
 * Homepage for Prism AI Services.
 * Focused on AI Voicebots + Workflow Automation for Kelowna businesses.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Prism AI Services',
  description: 'AI voicebots and workflow automation for Kelowna and Okanagan businesses. Save 15+ hours per week with custom AI solutions.',
  url: 'https://prismaiservices.ca',
  telephone: '',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Kelowna',
    addressRegion: 'BC',
    addressCountry: 'CA',
  },
  areaServed: [
    { '@type': 'City', name: 'Kelowna' },
    { '@type': 'City', name: 'West Kelowna' },
    { '@type': 'City', name: 'Penticton' },
    { '@type': 'City', name: 'Vernon' },
  ],
  priceRange: '$$',
};
---

<BaseLayout
  title="Prism AI | AI Voicebots & Workflow Automation for Kelowna Businesses"
  description="Prism AI builds custom AI voicebots and workflow automation for SMBs in Kelowna and the Okanagan. Save 15+ hours per week. Book a free consultation."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="home-hero">
    <div class="container">
      <div class="hero-badge">AI-Powered Business Automation · Kelowna, BC</div>
      <h1>AI Voicebots &amp; Workflow Automation<br /><span class="text-gradient">for Kelowna Businesses</span></h1>
      <p class="hero-sub">
        Stop losing leads after hours. Stop drowning in manual tasks.
        We build AI voicebots that answer your phones 24/7 and workflow automations
        that save your team 15+ hours every week.
      </p>
      <div class="hero-actions">
        <a href="#talk-to-ai" class="btn-primary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Talk to Our AI — Free</a>
        <a href="#pricing" class="btn-secondary">See Pricing</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">15+</span>
          <span class="stat-desc">Hours saved per week</span>
        </div>
        <div class="stat">
          <span class="stat-num">24/7</span>
          <span class="stat-desc">AI answers your calls</span>
        </div>
        <div class="stat">
          <span class="stat-num">3.2x</span>
          <span class="stat-desc">More leads captured</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section id="services" class="services-overview">
    <div class="container">
      <h2 class="section-title">Two Services. One Goal: Free Up Your Time.</h2>
      <p class="section-sub">We specialize in exactly two things — and we do them exceptionally well.</p>
      <div class="services-duo">
        <a href="/services/ai-voicebots" class="service-pillar card">
          <div class="service-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3>AI Voicebots</h3>
          <p>Custom voice AI that answers calls, books appointments, qualifies leads, and handles support — 24/7, sounding natural and on-brand.</p>
          <span class="service-cta">Learn more &rarr;</span>
        </a>
        <a href="/services/workflow-automation" class="service-pillar card">
          <div class="service-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
          </div>
          <h3>Workflow Automation</h3>
          <p>End-to-end automation of lead follow-up, CRM updates, invoicing, email sequences, and more. We connect your tools and eliminate busywork.</p>
          <span class="service-cta">Learn more &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="process" class="process-section">
    <div class="container">
      <h2 class="section-title">How It Works</h2>
      <p class="section-sub">From first conversation to live automation in as little as two weeks.</p>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">1</div>
          <h3>Discovery Call</h3>
          <p>We learn about your business, pain points, and goals. No jargon, no pressure — just a real conversation about what's costing you time.</p>
        </div>
        <div class="step-card">
          <div class="step-number">2</div>
          <h3>Custom Build</h3>
          <p>We design and build your AI voicebot or automation workflow, tailored to your exact business processes and tools.</p>
        </div>
        <div class="step-card">
          <div class="step-number">3</div>
          <h3>Launch &amp; Test</h3>
          <p>We deploy, test thoroughly, and make sure everything works seamlessly with your existing setup before going live.</p>
        </div>
        <div class="step-card">
          <div class="step-number">4</div>
          <h3>Optimize &amp; Support</h3>
          <p>We monitor performance, fine-tune based on real data, and provide ongoing support to maximize your ROI.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Free Pilot (Wedge Strategy) -->
  <section id="pilot" class="pilot-section">
    <div class="container">
      <h2 class="section-title">Try Before You Commit — Free 4-Week Pilot</h2>
      <p class="section-sub">We'll build and deploy one AI voicebot or automation workflow with predefined success metrics. No cost until you see results.</p>
      <div class="pilot-grid">
        <div class="pilot-step">
          <div class="pilot-num">1</div>
          <h3>Define Success Metrics</h3>
          <p>Together we decide what success looks like — calls answered, leads captured, hours saved, appointments booked. Concrete numbers, not vague promises.</p>
        </div>
        <div class="pilot-step">
          <div class="pilot-num">2</div>
          <h3>We Build &amp; Deploy</h3>
          <p>We build your custom AI solution and deploy it live within 2 weeks. Full integration with your existing tools. BC PIPA compliant from day one.</p>
        </div>
        <div class="pilot-step">
          <div class="pilot-num">3</div>
          <h3>You Decide</h3>
          <p>After 4 weeks of real data, you decide. If the numbers speak for themselves, we continue. If not, you walk away — no invoice, no hard feelings.</p>
        </div>
      </div>
      <div class="pilot-cta">
        <a href="#talk-to-ai" class="btn-primary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Start Your Free Pilot</a>
        <span class="pilot-note">No credit card · No contract · Real results in 4 weeks</span>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="pricing-section">
    <div class="container">
      <h2 class="section-title">Simple, Transparent Pricing</h2>
      <p class="section-sub">No hidden fees. No long-term contracts. Cancel anytime.</p>
      <div class="pricing-grid">
        <div class="pricing-card card">
          <div class="pricing-tier">Starter</div>
          <div class="pricing-price">$497 <span>CAD/mo</span></div>
          <p class="pricing-desc">Perfect for solo operators and small teams getting started with AI.</p>
          <ul class="pricing-features">
            <li>1 AI voicebot or automation workflow</li>
            <li>Up to 500 calls/month or 1,000 automation runs</li>
            <li>Basic analytics dashboard</li>
            <li>Email support</li>
            <li>Monthly optimization review</li>
          </ul>
          <a href="#talk-to-ai" class="btn-secondary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Get Started</a>
        </div>
        <div class="pricing-card card pricing-featured">
          <div class="pricing-popular">Most Popular</div>
          <div class="pricing-tier">Growth</div>
          <div class="pricing-price">$997 <span>CAD/mo</span></div>
          <p class="pricing-desc">For growing businesses ready to automate multiple processes.</p>
          <ul class="pricing-features">
            <li>Up to 3 voicebots or automation workflows</li>
            <li>Up to 2,000 calls/month or 5,000 automation runs</li>
            <li>Advanced analytics &amp; reporting</li>
            <li>Priority support</li>
            <li>Bi-weekly optimization calls</li>
            <li>CRM &amp; tool integrations included</li>
          </ul>
          <a href="#talk-to-ai" class="btn-primary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Get Started</a>
        </div>
        <div class="pricing-card card">
          <div class="pricing-tier">Enterprise</div>
          <div class="pricing-price">Custom</div>
          <p class="pricing-desc">For established businesses with complex automation needs.</p>
          <ul class="pricing-features">
            <li>Unlimited voicebots &amp; automations</li>
            <li>Unlimited calls &amp; automation runs</li>
            <li>Custom integrations &amp; API development</li>
            <li>Dedicated account manager</li>
            <li>Weekly strategy calls</li>
            <li>White-label options available</li>
          </ul>
          <a href="#talk-to-ai" class="btn-secondary" onclick="if(window.startAICall){event.preventDefault();startAICall();}">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof / Results -->
  <section class="results-section">
    <div class="container">
      <h2 class="section-title">What You Can Expect</h2>
      <p class="section-sub">Real results our clients are seeing with AI automation.</p>
      <div class="results-grid">
        <div class="result-card card">
          <div class="result-quote">"We were missing 30% of our after-hours calls. Now every call gets answered instantly and leads are booked automatically."</div>
          <div class="result-attr">
            <strong>— Real Estate Agency, Kelowna</strong>
            <span>AI Voicebot + CRM Integration</span>
          </div>
        </div>
        <div class="result-card card">
          <div class="result-quote">"Our team was spending 12 hours a week on manual data entry between systems. That's now fully automated."</div>
          <div class="result-attr">
            <strong>— Trades Company, West Kelowna</strong>
            <span>Workflow Automation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Kelowna Local CTA -->
  <section class="local-section">
    <div class="container">
      <div class="local-card">
        <h2>Built in Kelowna. Built for the Okanagan.</h2>
        <p>We're not a faceless agency in another time zone. Prism AI is based right here in Kelowna, BC. We understand the local economy — from wineries and tourism operators to trades businesses and real estate agencies. We build AI that works for how you do business.</p>
        <a href="/kelowna-ai-services" class="btn-secondary">See Our Local Services &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA / Talk to AI -->
  <section id="talk-to-ai" class="cta-final">
    <div class="container">
      <div class="cta-final-card">
        <div class="cta-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h2>Ready to See What AI Can Do for Your Business?</h2>
        <p>Talk to our AI concierge right now — it takes 2 minutes and you'll get a clear picture of what's possible. No forms, no waiting.</p>
        <button class="btn-primary btn-lg" onclick="startAICall();">
          Start Your Free AI Call
        </button>
        <span class="cta-note">Free · 2 minutes · No commitment</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .home-hero {
    padding: 7rem 0 5rem;
    text-align: center;
    background: radial-gradient(ellipse at top, rgba(108, 60, 225, 0.15) 0%, transparent 55%);
  }
  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: rgba(108, 60, 225, 0.12);
    border: 1px solid rgba(108, 60, 225, 0.3);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: 2rem;
  }
  .home-hero h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .hero-sub {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 620px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }
  .hero-stats {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .stat-num { font-size: 2rem; font-weight: 800; color: var(--color-primary-light); }
  .stat-desc { font-size: 0.85rem; color: var(--color-text-muted); }

  /* Services Overview */
  .services-overview { background: var(--color-bg-card); }
  .section-title { font-size: 2rem; text-align: center; margin-bottom: 0.75rem; }
  .section-sub { text-align: center; color: var(--color-text-muted); margin-bottom: 3rem; font-size: 1.1rem; }
  .services-duo {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  .service-pillar {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2.5rem;
  }
  .service-pillar:hover { color: inherit; }
  .service-icon { color: var(--color-primary-light); }
  .service-pillar h3 { font-size: 1.5rem; }
  .service-pillar p { color: var(--color-text-muted); line-height: 1.7; flex: 1; }
  .service-cta { color: var(--color-secondary); font-weight: 600; font-size: 0.95rem; }

  /* Process Steps */
  .process-section { padding: 5rem 0; }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }
  .step-card {
    text-align: center;
    padding: 2rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: rgba(108, 60, 225, 0.05);
    transition: transform 0.2s, border-color 0.2s;
  }
  .step-card:hover { transform: translateY(-4px); border-color: var(--color-primary-light); }
  .step-number {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white; font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;
  }
  .step-card h3 { font-size: 1.15rem; margin-bottom: 0.75rem; }
  .step-card p { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6; }

  /* Free Pilot */
  .pilot-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, rgba(108, 60, 225, 0.08), rgba(6, 182, 212, 0.05));
  }
  .pilot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .pilot-step {
    text-align: center;
    padding: 2rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
  }
  .pilot-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 50%;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));
    color: white; font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem;
  }
  .pilot-step h3 { font-size: 1.15rem; margin-bottom: 0.75rem; }
  .pilot-step p { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.6; }
  .pilot-cta { text-align: center; }
  .pilot-note {
    display: block;
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* Pricing */
  .pricing-section { background: var(--color-bg-card); }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    align-items: start;
  }
  .pricing-card {
    text-align: center;
    padding: 2.5rem 2rem;
    position: relative;
  }
  .pricing-featured {
    border-color: var(--color-primary-light);
    background: linear-gradient(135deg, rgba(108, 60, 225, 0.1), rgba(6, 182, 212, 0.05));
  }
  .pricing-popular {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white;
    padding: 0.25rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .pricing-tier {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary-light);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .pricing-price {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text-heading);
    margin-bottom: 0.5rem;
  }
  .pricing-price span {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }
  .pricing-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .pricing-features {
    list-style: none;
    text-align: left;
    margin-bottom: 2rem;
  }
  .pricing-features li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.95rem;
    padding-left: 1.5rem;
    position: relative;
  }
  .pricing-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-success);
    font-weight: 700;
  }

  /* Results / Social Proof */
  .results-section { padding: 5rem 0; }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  .result-card { padding: 2.5rem; }
  .result-quote {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  .result-attr {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .result-attr strong { font-size: 0.95rem; color: var(--color-text-heading); }
  .result-attr span { font-size: 0.85rem; color: var(--color-primary-light); }

  /* Local Section */
  .local-section { background: var(--color-bg-card); }
  .local-card {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .local-card h2 { font-size: 2rem; margin-bottom: 1.25rem; }
  .local-card p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* Final CTA */
  .cta-final { padding: 5rem 0; }
  .cta-final-card {
    text-align: center;
    background: linear-gradient(135deg, rgba(108, 60, 225, 0.15), rgba(6, 182, 212, 0.1));
    border: 1px solid rgba(108, 60, 225, 0.3);
    border-radius: var(--radius);
    padding: 4rem 2rem;
    max-width: 650px;
    margin: 0 auto;
  }
  .cta-icon { color: var(--color-primary-light); margin-bottom: 1.5rem; }
  .cta-final-card h2 { font-size: 1.75rem; margin-bottom: 1rem; }
  .cta-final-card p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .btn-lg {
    font-size: 1.15rem;
    padding: 1rem 2.5rem;
    cursor: pointer;
    animation: pulse-glow 2s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(108, 60, 225, 0.4); }
    50% { box-shadow: 0 0 20px 4px rgba(108, 60, 225, 0.3); }
  }
  .cta-note {
    display: block;
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .hero-stats { flex-direction: column; align-items: center; gap: 1.5rem; }
    .pricing-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }
</style>
