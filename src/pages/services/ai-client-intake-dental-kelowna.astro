---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const pageUrl = 'https://prismaiservices.netlify.app/services/ai-client-intake-dental-kelowna/';
const faqItems = [
  {
    question: 'How can a Kelowna dental clinic automate new patient intake with AI?',
    answer: 'AI intake can collect patient details, preferred appointment windows, insurance basics, and treatment intent before your front desk follows up.'
  },
  {
    question: 'Will AI intake replace my reception team?',
    answer: 'No. It handles repetitive intake and scheduling tasks so staff can focus on patient care, billing exceptions, and treatment coordination.'
  },
  {
    question: 'Can the system work after-hours and on weekends?',
    answer: 'Yes. AI intake workflows run 24/7 and sync captured leads into your CRM or booking process immediately.'
  }
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'AI Client Intake for Dental in Kelowna',
      provider: { '@type': 'Organization', name: 'Prism AI', url: 'https://prismaiservices.netlify.app' },
      areaServed: { '@type': 'City', name: 'Kelowna' },
      serviceType: 'Dental client intake automation',
      url: pageUrl,
      description: 'Prism AI helps Kelowna dental clinics automate patient intake, reduce front-desk pressure, and increase booked appointments.'
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } }))
    },
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      name: 'AI Client Intake for Dental in Kelowna | Prism AI',
      url: pageUrl,
      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.quick-answer p'] }
    }
  ]
};
---

<BaseLayout
  title="AI Client Intake for Dental in Kelowna | Prism AI"
  description="Prism AI helps Kelowna dental clinics automate patient intake and appointment capture with 24/7 conversational AI workflows."
  canonical={pageUrl}
  jsonLd={jsonLd}
>
  <section class="container page">
    <h1>AI Client Intake for Dental in Kelowna</h1>
    <div class="quick-answer"><p>Prism AI builds AI intake workflows for Kelowna dental clinics that collect patient information, pre-qualify requests, and route ready-to-book appointments without adding front-desk headcount.</p></div>

    <h2>What is AI client intake for dental clinics?</h2>
    <p>It is an automated workflow that captures key patient details through chat, voice, or web forms, then sends structured data to your team. This removes repetitive admin and speeds up response time.</p>

    <h2>How does AI intake work for Kelowna dental practices?</h2>
    <p>We configure intake logic for new patients, emergency cases, and hygiene follow-ups. The system asks the right questions, captures consent and contact details, and creates clear handoff records for your team.</p>

    <h2>Typical first-month deliverables</h2>
    <ul>
      <li>Clinic-specific intake scripts and workflows</li>
      <li>Calendar and CRM handoff mapping</li>
      <li>Response time and conversion tracking dashboard</li>
      <li>14-day optimization cycle after launch</li>
    </ul>

    <p><a href="/scorecard">Take the free AI readiness scorecard</a> and identify your biggest intake bottleneck in under 5 minutes.</p>
  </section>

  <FAQ items={faqItems} heading="AI Dental Intake FAQ for Kelowna Clinics" />
</BaseLayout>

<style>
.page{padding:3rem 0 2rem;max-width:860px}
.quick-answer{border:1px solid var(--color-border);padding:1rem 1.25rem;border-radius:12px;background:rgba(6,182,212,.08);margin:1rem 0 1.5rem}
</style>
