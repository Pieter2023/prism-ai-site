---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const pageUrl = 'https://prismaiservices.ca/services/ai-intake-triage-legal-kelowna/';
const faqItems = [
  { question: 'How does AI intake triage help Kelowna law firms?', answer: 'It captures matter type, urgency, and contact details quickly so firms can prioritize high-fit consults and reduce response delays.' },
  { question: 'Can AI triage route urgent legal matters immediately?', answer: 'Yes. Escalation rules can notify the right team member based on urgency and practice area.' },
  { question: 'What outcomes improve first?', answer: 'Most firms see faster first response, better intake consistency, and more qualified consult bookings.' }
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Service', name: 'AI Intake Triage for Legal in Kelowna', provider: { '@type': 'Organization', name: 'Prism AI', url: 'https://prismaiservices.ca' }, areaServed: { '@type': 'City', name: 'Kelowna' }, serviceType: 'Legal intake triage automation', url: pageUrl, description: 'Prism AI helps Kelowna legal teams automate intake triage and improve consult conversion.' },
    { '@type': 'FAQPage', mainEntity: faqItems.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })) },
    { '@type': 'WebPage', '@id': `${pageUrl}#webpage`, name: 'AI Intake Triage for Legal in Kelowna | Prism AI', url: pageUrl, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.quick-answer p'] } }
  ]
};
---

<BaseLayout title="AI Intake Triage for Legal in Kelowna | Prism AI" description="Prism AI helps Kelowna law firms automate client intake triage to speed response and increase qualified consult bookings." canonical={pageUrl} jsonLd={jsonLd}>
  <section class="container page">
    <h1>AI Intake Triage for Legal in Kelowna</h1>
    <div class="quick-answer"><p>Prism AI helps Kelowna law firms automate intake triage so new enquiries are qualified faster, urgent matters are routed correctly, and your team can focus on high-value legal work.</p></div>
    <h2>What is AI intake triage for legal practices?</h2>
    <p>It is a structured workflow that asks initial intake questions, tags urgency and matter type, then routes prospects into the right legal follow-up path.</p>
    <h2>How does it work for Kelowna legal teams?</h2>
    <p>We map your practice areas, intake criteria, and escalation paths so each enquiry gets a consistent first response and your team receives actionable lead context.</p>
    <h2>Implementation checklist</h2>
    <ul><li>Define intake logic by practice area</li><li>Set urgency and escalation criteria</li><li>Integrate handoff to CRM/case pipeline</li><li>Track consult conversion and response SLA weekly</li></ul>
    <p>Start with the <a href="/audit">Free AI Business Audit</a> to identify your highest-impact intake bottlenecks.</p>
  </section>
  <FAQ items={faqItems} heading="AI Legal Intake Triage FAQ for Kelowna" />
</BaseLayout>

<style>.page{padding:3rem 0 2rem;max-width:860px}.quick-answer{border:1px solid var(--color-border);padding:1rem 1.25rem;border-radius:12px;background:rgba(6,182,212,.08);margin:1rem 0 1.5rem}</style>
