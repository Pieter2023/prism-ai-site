---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const pageUrl = 'https://prismaiservices.ca/services/ai-follow-up-automation-dental-kelowna/';
const faqItems = [
  { question: 'How can AI follow-up automation help Kelowna dental clinics?', answer: 'AI follow-up workflows send timely post-visit messages, reactivation reminders, and treatment prompts to improve patient return rates and scheduling consistency.' },
  { question: 'Can AI follow-up reduce front-desk admin load?', answer: 'Yes. Automated reminders and two-way patient messaging reduce repetitive outbound calls and manual reminder tasks.' },
  { question: 'What KPIs should a clinic track?', answer: 'Track patient reactivation rate, follow-up response rate, rebook conversion, and average days-to-next-appointment.' }
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Service', name: 'AI Follow-Up Automation for Dental in Kelowna', provider: { '@type': 'Organization', name: 'Prism AI', url: 'https://prismaiservices.ca' }, areaServed: { '@type': 'City', name: 'Kelowna' }, serviceType: 'Dental follow-up automation', url: pageUrl, description: 'Prism AI helps Kelowna dental clinics automate patient follow-up and improve rebooking outcomes.' },
    { '@type': 'FAQPage', mainEntity: faqItems.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })) },
    { '@type': 'WebPage', '@id': `${pageUrl}#webpage`, name: 'AI Follow-Up Automation for Dental in Kelowna | Prism AI', url: pageUrl, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.quick-answer p'] } }
  ]
};
---

<BaseLayout title="AI Follow-Up Automation for Dental in Kelowna | Prism AI" description="Prism AI helps Kelowna dental clinics automate patient follow-up, increase rebook rates, and reduce manual reminder workload." canonical={pageUrl} jsonLd={jsonLd}>
  <section class="container page">
    <h1>AI Follow-Up Automation for Dental in Kelowna</h1>
    <div class="quick-answer"><p>Prism AI helps Kelowna dental clinics automate patient follow-up with smart reminders and reactivation workflows that improve rebooking rates while reducing front-desk admin pressure.</p></div>

    <h2>What is AI follow-up automation for dental practices?</h2>
    <p>It is an automated communication workflow that sends post-visit follow-ups, rebook reminders, and treatment prompts based on patient status and appointment history.</p>

    <h2>How does it work for Kelowna dental teams?</h2>
    <p>We map your patient journey, configure follow-up timing by appointment type, and trigger personalized outreach sequences that move patients toward their next booking.</p>

    <h2>Implementation checklist</h2>
    <ul><li>Define follow-up windows by treatment type</li><li>Enable two-way response handling for patient questions</li><li>Automate reactivation for overdue patients</li><li>Track rebook conversion and no-show trend weekly</li></ul>

    <p>Start with the <a href="/audit">Free AI Business Audit</a> to identify your highest-impact follow-up opportunity.</p>
  </section>

  <FAQ items={faqItems} heading="AI Dental Follow-Up Automation FAQ for Kelowna" />
</BaseLayout>

<style>.page{padding:3rem 0 2rem;max-width:860px}.quick-answer{border:1px solid var(--color-border);padding:1rem 1.25rem;border-radius:12px;background:rgba(6,182,212,.08);margin:1rem 0 1.5rem}</style>
