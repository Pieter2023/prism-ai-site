---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const pageUrl = 'https://prismaiservices.netlify.app/services/ai-client-intake-legal-kelowna/';
const faqItems = [
  {
    question: 'How can a Kelowna law firm use AI for client intake?',
    answer: 'AI intake workflows can capture matter type, urgency, contact details, and preferred consultation windows, then route qualified leads to the right team member.'
  },
  {
    question: 'Does AI intake work for after-hours legal enquiries?',
    answer: 'Yes. AI can respond immediately after-hours, gather essential facts, and trigger follow-up alerts so urgent leads are not missed overnight.'
  },
  {
    question: 'Will AI intake replace legal judgement?',
    answer: 'No. It handles repetitive intake and triage. Legal advice and case strategy remain with your lawyers.'
  }
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'AI Client Intake for Legal in Kelowna',
      provider: { '@type': 'Organization', name: 'Prism AI', url: 'https://prismaiservices.netlify.app' },
      areaServed: { '@type': 'City', name: 'Kelowna' },
      serviceType: 'Legal intake automation',
      url: pageUrl,
      description: 'Prism AI helps Kelowna law firms automate client intake, speed up first response, and improve consult booking consistency.'
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } }))
    },
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      name: 'AI Client Intake for Legal in Kelowna | Prism AI',
      url: pageUrl,
      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.quick-answer p'] }
    }
  ]
};
---

<BaseLayout
  title="AI Client Intake for Legal in Kelowna | Prism AI"
  description="Prism AI builds AI client intake for Kelowna law firms to capture and qualify enquiries faster, including after-hours leads."
  canonical={pageUrl}
  jsonLd={jsonLd}
>
  <section class="container page">
    <h1>AI Client Intake for Legal in Kelowna</h1>
    <div class="quick-answer"><p>Prism AI helps Kelowna law firms automate first-touch client intake, capture high-intent enquiries after-hours, and route qualified consultations to the right lawyer faster across Canada-focused workflows.</p></div>

    <h2>What is AI client intake for legal services?</h2>
    <p>AI legal intake automates repetitive front-end questions so your team receives structured lead details before the first consult. This reduces admin load and improves response speed.</p>

    <h2>How does it work for Kelowna law firms?</h2>
    <p>We map practice areas, intake questions, and escalation rules. The system collects contact and matter details, tags urgency, and routes enquiries to your intake coordinator or assigned lawyer.</p>

    <h2>Implementation checklist</h2>
    <ul>
      <li>Define intake logic per practice area</li>
      <li>Set conflict-check and escalation guardrails</li>
      <li>Connect intake outputs to your CRM/case pipeline</li>
      <li>Review conversion outcomes weekly for optimization</li>
    </ul>

    <p><a href="/scorecard">Start the free AI readiness scorecard</a> to identify your biggest intake bottleneck in minutes.</p>
  </section>

  <FAQ items={faqItems} heading="AI Legal Intake FAQ for Kelowna" />
</BaseLayout>

<style>
.page{padding:3rem 0 2rem;max-width:860px}
.quick-answer{border:1px solid var(--color-border);padding:1rem 1.25rem;border-radius:12px;background:rgba(6,182,212,.08);margin:1rem 0 1.5rem}
</style>
