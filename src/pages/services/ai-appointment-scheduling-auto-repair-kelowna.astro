---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';

const pageUrl = 'https://prismaiservices.netlify.app/services/ai-appointment-scheduling-auto-repair-kelowna/';
const faqItems = [
  { question: 'Can AI schedule auto-repair appointments after-hours?', answer: 'Yes. AI schedulers can capture issue type, preferred time, and contact details after-hours, then book into your calendar rules.' },
  { question: 'How does AI reduce no-shows for repair bookings?', answer: 'Automated reminders and confirmation messages reduce missed appointments and keep bays utilized.' },
  { question: 'Can urgent breakdown requests be escalated?', answer: 'Yes. Urgent requests can trigger priority alerts for immediate callback or dispatch workflows.' }
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Service', name: 'AI Appointment Scheduling for Auto Repair in Kelowna', provider: { '@type': 'Organization', name: 'Prism AI', url: 'https://prismaiservices.netlify.app' }, areaServed: { '@type': 'City', name: 'Kelowna' }, serviceType: 'Auto repair appointment automation', url: pageUrl, description: 'Prism AI automates appointment scheduling for Kelowna auto-repair businesses to improve booking speed and shop utilization.' },
    { '@type': 'FAQPage', mainEntity: faqItems.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })) },
    { '@type': 'WebPage', '@id': `${pageUrl}#webpage`, name: 'AI Appointment Scheduling for Auto Repair in Kelowna | Prism AI', url: pageUrl, speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.quick-answer p'] } }
  ]
};
---

<BaseLayout title="AI Appointment Scheduling for Auto Repair in Kelowna | Prism AI" description="Prism AI helps Kelowna auto-repair shops automate appointment scheduling, after-hours intake, and reminder workflows." canonical={pageUrl} jsonLd={jsonLd}>
  <section class="container page">
    <h1>AI Appointment Scheduling for Auto Repair in Kelowna</h1>
    <div class="quick-answer"><p>Prism AI helps Kelowna auto-repair shops automate appointment scheduling with faster first response, after-hours booking capture, and fewer no-shows through intelligent reminders.</p></div>
    <h2>What is AI appointment scheduling?</h2>
    <p>It is an automated booking workflow that handles common appointment requests, validates availability, and routes edge cases to your service advisor.</p>
    <h2>How does it work for Kelowna repair shops?</h2>
    <p>We configure your service categories, estimated durations, and scheduling constraints. The system captures customer details and books accurate slots with confirmation messages.</p>
    <h2>Operational rollout steps</h2>
    <ul><li>Define booking rules by service type</li><li>Set after-hours intake handling</li><li>Connect reminder cadence (SMS/email)</li><li>Track no-shows and booking conversion weekly</li></ul>
    <p><a href="/scorecard">Start the free AI readiness scorecard</a> to benchmark your scheduling efficiency.</p>
  </section>
  <FAQ items={faqItems} heading="AI Auto Repair Scheduling FAQ for Kelowna" />
</BaseLayout>

<style>.page{padding:3rem 0 2rem;max-width:860px}.quick-answer{border:1px solid var(--color-border);padding:1rem 1.25rem;border-radius:12px;background:rgba(6,182,212,.08);margin:1rem 0 1.5rem}</style>
